{
  "manifest_version": 3,
  "name": "Tender PDF Extractor Pro",
  "version": "3.0",
  "description": "Floating button for PDF pages + Universal Drag & Drop Modal (Ctrl+Shift+Y)",
  "permissions": ["clipboardWrite", "activeTab"],
  "host_permissions": ["<all_urls>", "file:///*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "toggle-pdf-extractor": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Toggle the Drag & Drop Modal"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["libs/pdf.mjs", "libs/pdf.worker.mjs"],
      "matches": ["<all_urls>", "file:///*"]
    }
  ]
}
