{
  "manifest_version": 3,
  "name": "PDF JSON Extractor",
  "version": "1.0",

  "permissions": [
    "clipboardWrite"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": [
        "<all_urls>",
        "file:///*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "libs/pdf.mjs",
        "libs/pdf.worker.mjs"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}